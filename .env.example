# ============================================================
# AI写作平台 — 环境配置模板
# 复制此文件为 .env.local 并填入实际值
# ============================================================
# ⚠️  生产环境必须修改所有标记 ⚠️ 的项
# ============================================================

# ---- 数据库 ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=                    # ⚠️ 改为实际密码
DB_NAME=p_wyrunwu_com

# ---- V免签 PHP 支付后台 ----
PHP_API_BASE=http://localhost:8080
PHP_API_KEY=                    # ⚠️ 改为 V免签密钥
NEXT_PUBLIC_SITE_URL=https://你的域名.com

# ---- 邮件服务（QQ邮箱 SMTP）----
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com    # ⚠️ 填入QQ邮箱地址
SMTP_PASS=your_auth_code       # ⚠️ QQ邮箱→设置→账户→POP3/SMTP→生成授权码
SMTP_FROM=your_email@qq.com

# ---- 管理员账号 ⚠️ 务必修改 ----
ADMIN_USERNAME=                 # ⚠️ 填入管理员用户名
ADMIN_PASSWORD=                 # ⚠️ 填入强密码

# ---- JWT 密钥 ⚠️ 务必设置 ----
# 生成方式: openssl rand -hex 32
JWT_SECRET=                     # ⚠️ 填入随机32字节十六进制字符串

# ---- AI 大模型配置 ----
AI_PROVIDER=deepseek
AI_API_KEY=                     # ⚠️ 去 https://platform.deepseek.com 获取
AI_BASE_URL=                    # 留空用默认地址
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ---- 天行数据 API ----
TIANAPI_KEY=                    # ⚠️ 去 https://www.tianapi.com 注册获取

# ---- 调试选项 ----
MOCK_AI=false
FREE_CREDITS=10

# ---- 站点信息 ----
SITE_NAME=AI爆文生成器
SITE_DESCRIPTION=专业的AI文章生成工具，支持多领域智能创作
